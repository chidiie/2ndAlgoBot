# ─────────────────────────────────────────────────────────────────────────────
# AlgoBot Environment Variables
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER commit .env to git — it contains your secrets
# ─────────────────────────────────────────────────────────────────────────────

# MetaApi credentials (from https://metaapi.cloud)
METAAPI_TOKEN=your_metaapi_token_here
METAAPI_ACCOUNT_ID=your_metaapi_account_id_here

# Telegram bot (from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=987654321

# Trading mode: Paper | Demo | Live
TRADING_MODE=Paper

# Instruments to trade (leave INSTRUMENT_1 blank to trade only EUR/USD)
INSTRUMENT_0=EURUSD
INSTRUMENT_1=GBPUSD
